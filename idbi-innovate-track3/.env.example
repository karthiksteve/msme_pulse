# =============================================================
# MSME Pulse — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================

# ── App ───────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-in-production-use-a-256-bit-random-key

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=msme_pulse
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/msme_pulse

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── ML Models ─────────────────────────────────────────────────
MODEL_PATH=./backend/models

# ── External APIs (Sandbox — replace with real credentials) ───
GST_API_URL=https://api.sandbox.gst.gov.in
AA_API_URL=https://api.sandbox.accountaggregator.gov.in

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
